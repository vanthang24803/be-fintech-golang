PORT=8386
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go_backend
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/go_backend?sslmode=disable

# JWT Secrets
JWT_SECRET=super_secret_jwt_key_for_dev_only
JWT_REFRESH_SECRET=super_secret_refresh_key_for_dev_only

# Google OAuth (Register at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URL=http://localhost:8386/api/v1/auth/google/callback

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_JSON=configs/firebase-service-account.json

# Redis (For Task Queue)
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# WebAuthn / FIDO2
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Expense Manager
WEBAUTHN_ORIGIN=http://localhost:8386
